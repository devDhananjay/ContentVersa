    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://contentverse.co.in" },
    { "key": "blogSlug", "value": "the-shipping-mindset-2026-creators" },
    { "key": "blogId", "value": "BLOG_ID_HERE" },
    { "key": "userId", "value": "USER_ID_HERE" },
    { "key": "commentId", "value": "COMMENT_ID_HERE" },
    { "key": "pollSlug", "value": "ai-replace-jobs" },
