              "query": [{ "key": "email", "value": "dhananjays124@gmail.com" }]
            },
            "description": "Lookup single user by email → returns user.id for PATCH."
          }
        },
        {
          "name": "POST /api/admin/users (create user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
