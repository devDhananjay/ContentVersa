  "item": [
    {
      "name": "01 — Auth",
      "description": "app/api/auth/*",
      "item": [
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Session user + profile + reading.totalFormatted when logged in."
          }
        },
        {
          "name": "GET /api/me/reading",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/me/reading",
            "description": "Total reading time + recent articles (requires cv_session)."
          }
        },
        {
          "name": "POST /api/auth/sign-in",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@contentverse.app\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sign-in",
            "description": "Email/password login. Sets HttpOnly cookie `cv_session`."
          }
        },
        {
          "name": "POST /api/auth/sign-up",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"testuser123\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sign-up"
          }
        },
        {
          "name": "POST /api/auth/sign-out",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/sign-out",
            "description": "Clears session cookie."
          }
        },
        {
          "name": "GET /api/auth/google/login",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/google/login?next=/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google", "login"],
              "query": [{ "key": "next", "value": "/dashboard", "description": "Redirect after login" }]
            },
            "description": "302 redirect to Google OAuth. Use in browser."
          }
        },
        {
          "name": "GET /api/auth/google/callback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/google/callback?code=&state=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google", "callback"],
              "query": [
                { "key": "code", "value": "" },
                { "key": "state", "value": "" }
              ]
            },
            "description": "Google redirects here. Browser-only flow."
          }
        },
        {
          "name": "POST /api/auth/firebase",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"FIREBASE_ID_TOKEN_FROM_CLIENT\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/firebase",
            "description": "Phone OTP via Firebase. Client sends Firebase ID token."
          }
        }
      ]
    },
    {
      "name": "01b — Users & Follow",
