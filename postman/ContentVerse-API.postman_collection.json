            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dhananjays124@gmail.com\",\n  \"role\": \"SUPER_ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/promote",
            "description": "Super Admin session OR x-admin-bootstrap-secret header."
          }
        },
        {
          "name": "PATCH /api/admin/users/:id (update role)",
