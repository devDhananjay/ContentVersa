12:T7c1,{"@context":"https://schema.org","@type":"FAQPage","@id":"https://contentverse.co.in/huid-verification#faq","mainEntity":[{"@type":"Question","name":"What is HUID in gold jewellery?","acceptedAnswer":{"@type":"Answer","text":"HUID (Hallmark Unique ID) is a 6-character alphanumeric code laser-marked on BIS-hallmarked gold jewellery since 1 July 2021. Each piece gets a unique ID linked to purity, jeweller, weight and marking date in the official BIS database."}},{"@type":"Question","name":"How do I verify HUID online?","acceptedAnswer":{"@type":"Answer","text":"Enter the 6-character HUID from your jewellery into the verification tool on this page, sign in with a free ContentVerse account, and submit. The system checks the official BIS HUID database and returns hallmark details if the record exists."}},{"@type":"Question","name":"Is HUID verification free?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every registered user gets 5 free HUID verification checks. Jewellery shops and businesses needing higher volume can contact ContentVerse for API access."}},{"@type":"Question","name":"Where is the HUID marked on gold jewellery?","acceptedAnswer":{"@type":"Answer","text":"Look for a tiny laser engraving on the piece — often near the clasp, inner surface of a ring, or back of a pendant. It is a 6-character code (letters and numbers) alongside the BIS hallmark components."}},{"@type":"Question","name":"What if HUID verification fails?","acceptedAnswer":{"@type":"Answer","text":"A failed check may mean the code was entered incorrectly, the piece predates mandatory HUID (before July 2021), or the jewellery is not registered in the BIS database. Do not pay hallmark prices without a valid verification."}},{"@type":"Question","name":"Can I verify HUID without signing in?","acceptedAnswer":{"@type":"Answer","text":"Sign-in is required to prevent abuse and track your free verification quota. Creating a ContentVerse account is free and takes under a minute."}}]}c:["$","$