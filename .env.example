# =========================================================================
#  ContentVerse — example environment (copy to .env and fill in real values)
# =========================================================================

# -------- Database (Postgres — AWS RDS in production) --------
# Local dev (Docker): docker run --name cv-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=contentverse -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contentverse?schema=public"
# Production (AWS RDS — same VPC as EC2, security group must allow EC2 → RDS on 5432):
# DATABASE_URL="postgresql://contentverse:YOUR_PASSWORD@your-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/contentverse?sslmode=require"

# -------- Auth / sessions --------
JWT_SECRET="change-me-to-a-long-random-string"
# One-time / server promote via POST /api/admin/users/promote (header: x-admin-bootstrap-secret)
ADMIN_BOOTSTRAP_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Production server (OAuth — set on EC2, not baked like NEXT_PUBLIC):
APP_URL="https://contentverse.co.in"
# Production (AWS): https://contentverse.co.in
DEMO_MODE="1"

# -------- Google OAuth --------
# https://console.cloud.google.com/apis/credentials → OAuth client → Web app
# Authorized JavaScript origins: <NEXT_PUBLIC_APP_URL> (no path)
# Authorized redirect URIs (add each environment):
#   http://localhost:3001/api/auth/google/callback
#   https://contentverse.co.in/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------- Firebase (phone OTP auth) --------
# https://console.firebase.google.com → Project settings → SDK config (Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# Service-account JSON (single line) for verifying Firebase ID tokens + FCM push on the server.
# Firebase Console → Project settings → Service accounts → Generate new private key → minify to one line.
FIREBASE_ADMIN_CREDENTIALS=""
# Web push (FCM) — Firebase Console → Project settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Scheduled notification jobs (inactive readers, trending, weekly digest, push alerts)
# Push alerts: GET /api/cron/push-alerts?job=cricket|stocks
# Call: GET /api/cron/notifications?job=inactive|trending|weekly with header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Sports API — DB cache + quota-aware sync (RapidAPI Basic: 200/month, 1000/hour)
# Auto-sync: 1 API call every 4 hours (~180/month). Pages always read from DB.
# On AWS EC2: add a crontab entry (see deploy/cron/sports-sync.crontab.example).
# SPORTS_AUTO_SYNC=0              — disable automatic sync
# SPORTS_SYNC_INTERVAL_MS=14400000  — 4 hours (default)
# SPORTS_SYNC_MAX_CALLS=1         — calls per sync run (default)
# SPORTS_MONTHLY_API_LIMIT=200    — RapidAPI Basic hard limit
# SPORTS_HOURLY_API_LIMIT=1000
# SPORTS_BOOTSTRAP_MAX_CALLS=15   — max calls per bootstrap run
# SPORTS_SYNC_DELAY_MS=1500
# SPORTS_DISABLE_DB_CACHE=0
# SPORTS_ALLOW_LIVE_FALLBACK=1

# -------- AI writing tools (optional) --------
# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Free tier ~20 requests/day per model; code auto-falls back across models below.
GEMINI_TEXT_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.0-flash-exp"
# Daily AI cron: 2 articles/category (21 cats = 42/day). Free tier ~20 req/day — use DAILY_AI_MAX_TOTAL=20
DAILY_AI_PER_CATEGORY="2"
DAILY_AI_MAX_TOTAL="20"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# -------- Reels (Cloudinary — image + video) --------
# https://cloudinary.com/console → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# -------- Image uploads (AWS S3 — recommended for production) --------
# AWS Console → S3 → create bucket → IAM user with s3:PutObject permission
AWS_S3_BUCKET=""
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional CDN/CloudFront URL (e.g. https://cdn.contentverse.app) — omit to use direct S3 URL
AWS_S3_PUBLIC_URL=""

# -------- Local uploads fallback (dev / EC2 without S3) --------
# EC2: UPLOAD_DIR=/home/ec2-user/ContentVersa/data/uploads + nginx uploads-static.conf
UPLOAD_DIR=""

# -------- Redis cache (optional) --------
REDIS_URL=""

# -------- Finance / Markets (Yahoo Finance — free, no API key) --------
# Live Nifty, Sensex, gainers/losers via yahoo-finance2 (server-side).
# Server cache TTL (seconds). Default 300 — do not set below 60 in production.
# FINANCE_CACHE_TTL_SECONDS=300

# -------- Category live feeds --------
# TMDB (Movies) — https://www.themoviedb.org/settings/api
TMDB_API_KEY=""
TMDB_READ_ACCESS_TOKEN=""
# Product Hunt (Startups) — https://api.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_API_KEY=""
PRODUCT_HUNT_API_SECRET=""
# GitHub (Programming) — optional, raises search rate limit from 10 to 30/min
GITHUB_TOKEN=""
# https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=""
RAPIDAPI_CRICBUZZ_HOST="cricbuzz-cricket.p.rapidapi.com"

# -------- Email (newsletter + notification digests) --------
# GoDaddy Professional/Workspace: SMTP_HOST=smtpout.secureserver.net SMTP_PORT=465
# GoDaddy Microsoft 365: SMTP_HOST=smtp.office365.com SMTP_PORT=587
# Gmail: smtp.gmail.com + App Password | Zoho: smtp.zoho.in
EMAIL_FROM="writewith@contentverses.in"
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""

# -------- Monetization --------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=""
