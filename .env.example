# =========================================================================
#  ContentVerse — example environment (copy to .env and fill in real values)
# =========================================================================

# -------- Database (Postgres) --------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contentverse?schema=public"

# -------- Auth / sessions --------
JWT_SECRET="change-me-to-a-long-random-string"
# One-time / server promote via POST /api/admin/users/promote (header: x-admin-bootstrap-secret)
ADMIN_BOOTSTRAP_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Production server (OAuth — set on EC2, not baked like NEXT_PUBLIC):
APP_URL="https://contentverse.co.in"
# Production (AWS): https://contentverse.co.in
DEMO_MODE="1"

# -------- Google OAuth --------
# https://console.cloud.google.com/apis/credentials → OAuth client → Web app
# Authorized JavaScript origins: <NEXT_PUBLIC_APP_URL> (no path)
# Authorized redirect URIs (add each environment):
#   http://localhost:3001/api/auth/google/callback
#   https://contentverse.co.in/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------- Firebase (phone OTP auth) --------
# https://console.firebase.google.com → Project settings → SDK config (Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# Service-account JSON (single line) for verifying Firebase ID tokens + FCM push on the server.
# Firebase Console → Project settings → Service accounts → Generate new private key → minify to one line.
FIREBASE_ADMIN_CREDENTIALS=""
# Web push (FCM) — Firebase Console → Project settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Scheduled notification jobs (inactive readers, trending, weekly digest)
# Call: GET /api/cron/notifications?job=inactive|trending|weekly with header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Sports API — DB cache + quota-aware sync (RapidAPI Basic: 200/month, 1000/hour)
# Auto-sync: 1 API call every 4 hours (~180/month). Pages always read from DB.
# On Vercel: vercel.json cron hits /api/cron/sports-sync every 4 hours.
# SPORTS_AUTO_SYNC=0              — disable automatic sync
# SPORTS_SYNC_INTERVAL_MS=14400000  — 4 hours (default)
# SPORTS_SYNC_MAX_CALLS=1         — calls per sync run (default)
# SPORTS_MONTHLY_API_LIMIT=200    — RapidAPI Basic hard limit
# SPORTS_HOURLY_API_LIMIT=1000
# SPORTS_BOOTSTRAP_MAX_CALLS=15   — max calls per bootstrap run
# SPORTS_SYNC_DELAY_MS=1500
# SPORTS_DISABLE_DB_CACHE=0
# SPORTS_ALLOW_LIVE_FALLBACK=1

# -------- AI writing tools (optional) --------
# Google Gemini (primary) — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-1.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.0-flash-exp"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# -------- Image uploads (required on Vercel) --------
# Vercel Dashboard → your project → Storage → Blob → Connect
# This adds BLOB_READ_WRITE_TOKEN automatically on deploy.
BLOB_READ_WRITE_TOKEN=""

# -------- Redis cache (optional) --------
REDIS_URL=""

# -------- Finance / Markets (Yahoo Finance — free, no API key) --------
# Live Nifty, Sensex, gainers/losers via yahoo-finance2 (server-side).
# Data cached 5 min in Redis or in-memory fallback.
# https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=""
RAPIDAPI_CRICBUZZ_HOST="cricbuzz-cricket.p.rapidapi.com"

# -------- Email --------
EMAIL_FROM="hello@contentverse.app"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# -------- Monetization --------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=""
