# =========================================================================
#  ContentVerse — example environment (copy to .env and fill in real values)
# =========================================================================

# -------- Database (Postgres) --------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contentverse?schema=public"

# -------- Auth / sessions --------
JWT_SECRET="change-me-to-a-long-random-string"
# One-time / server promote via POST /api/admin/users/promote (header: x-admin-bootstrap-secret)
ADMIN_BOOTSTRAP_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Production server (OAuth — set on EC2, not baked like NEXT_PUBLIC):
APP_URL="https://contentverse.co.in"
# Production (AWS): https://contentverse.co.in
DEMO_MODE="1"

# -------- Google OAuth --------
# https://console.cloud.google.com/apis/credentials → OAuth client → Web app
# Authorized JavaScript origins: <NEXT_PUBLIC_APP_URL> (no path)
# Authorized redirect URIs (add each environment):
#   http://localhost:3001/api/auth/google/callback
#   https://contentverse.co.in/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------- Firebase (phone OTP auth) --------
# https://console.firebase.google.com → Project settings → SDK config (Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# Service-account JSON (single line) for verifying Firebase ID tokens on the server.
FIREBASE_ADMIN_CREDENTIALS=""

# -------- AI writing tools (optional) --------
# Google Gemini (primary) — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-1.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.0-flash-exp"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# -------- Image uploads (required on Vercel) --------
# Vercel Dashboard → your project → Storage → Blob → Connect
# This adds BLOB_READ_WRITE_TOKEN automatically on deploy.
BLOB_READ_WRITE_TOKEN=""

# -------- Redis cache (optional) --------
REDIS_URL=""

# -------- Email --------
EMAIL_FROM="hello@contentverse.app"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# -------- Monetization --------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=""
