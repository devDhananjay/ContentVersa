{
  "name": "contentverse",
  "version": "1.0.0",
  "private": true,
  "description": "ContentVerse — Read. Create. Grow. A next-generation AI-ready blog & content publishing platform.",
  "scripts": {
    "dev": "next dev --turbopack",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "build:server": "npm run build && node scripts/package-standalone.mjs",
    "start": "next start",
    "start:server": "NODE_ENV=production node build/server.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:local": "node scripts/db-push-local.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:assign-owner": "tsx prisma/assign-owner-content.ts",
    "db:seed-dashboard": "tsx prisma/seed-dashboard-owner.ts",
    "db:seed-seo": "tsx scripts/seed-seo-articles.ts",
    "db:seed-manual": "tsx scripts/seed-manual-articles.ts",
    "db:archive-discover": "tsx scripts/archive-discover-blogs.ts",
    "db:fix-covers": "tsx scripts/fix-missing-covers.ts",
    "db:fix-duplicate-covers": "tsx scripts/fix-duplicate-covers.ts",
    "db:audit-duplicates": "tsx scripts/audit-duplicate-blogs.ts",
    "db:regen-covers": "tsx scripts/regenerate-article-covers.ts",
    "db:expand-articles": "tsx scripts/expand-short-articles.ts",
    "db:daily-ai": "tsx scripts/daily-ai-articles.ts",
    "db:welcome-users": "tsx scripts/welcome-recent-users.ts",
    "db:promote-admin": "tsx prisma/promote-owner-admin.ts",
    "db:setup-admin": "tsx prisma/setup-admin-access.ts",
    "db:local": "bash scripts/start-local-db.sh",
    "db:tunnel": "bash scripts/db-tunnel.sh",
    "db:sync-env": "node scripts/sync-prod-db-env.mjs",
    "sports:sync": "tsx scripts/sports-sync.ts",
    "sports:bootstrap": "tsx scripts/sports-bootstrap-sync.ts"
  },
